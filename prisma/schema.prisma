// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🔐 ROLES (O coração da autorização unificada)
enum Role {
  SUPER_ADMIN // Você (Dono do SaaS)
  ORG_ADMIN   // O Cliente (ex: João da Paróquia)
  OPERATOR    // O Locutor do Bingo
}

// 🏢 TENANT (Substitui a antiga "Organization" - Inquilino do SaaS)
model Tenant {
  id        String   @id @default(cuid())
  name      String
  subdomain String   @unique // ex: saobento, rotary
  logoUrl   String?
  active    Boolean  @default(true)
  token     String?

  users     User[]
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 👤 USERS (Unifica Donos e Operadores na mesma tabela de autenticação)
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?  // Hashed via bcrypt
  role      Role     @default(ORG_ADMIN)
  operator  String?
  // RELAÇÃO COM TENANT
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId]) // Otimiza a busca quando listarmos "Todos os usuários de um Tenant"
}

// 🎉 EVENTS
model Event {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("DRAFT")
  drawnNumbers Int[]    @default([])
  isActive     Boolean  @default(false)

  // RELAÇÃO COM TENANT (Garante o isolamento dos dados)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sponsors     Sponsor[]
  cards        Card[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// 🤝 SPONSORS
model Sponsor {
  id        String  @id @default(cuid())
  name      String
  logoUrl   String?

  // RELAÇÃO COM EVENT
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// 🎟️ CARDS
model Card {
  id        String   @id @default(cuid())
  shortId   String   @unique // Garantia de unicidade no banco de dados!
  matrix    Json     // Armazena {B:[], I:[], N:[], G:[], O:[]}
  isSold    Boolean  @default(false)

  // RELAÇÃO COM EVENT
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([shortId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  tenantId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}